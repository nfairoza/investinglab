# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored — your real keys never leave your machine.

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Market / financial data (Financial Modeling Prep) ----
# Get a free key at https://site.financialmodelingprep.com/developer/docs
# Without this, the app runs in DEMO mode (labelled clearly).
MARKET_DATA_API_KEY=
FINANCIAL_DATA_API_KEY=
NEWS_API_KEY=

# ---- AI report generation (Claude / Anthropic) ----
# Get a key at https://console.anthropic.com
# Without this, the AI research memo and chat widget are disabled.
ANTHROPIC_API_KEY=
AI_API_KEY=
AI_MODEL=claude-sonnet-4-6

# ---- E*TRADE — read-only portfolio sync ----
# Get a free individual consumer key at https://developer.etrade.com
# OAuth 1.0a — the app never sees your password, only a server-side token.
ETRADE_CONSUMER_KEY=
ETRADE_CONSUMER_SECRET=
# Set to true while using sandbox/test keys from developer.etrade.com
# Remove (or set to false) when you receive production keys.
ETRADE_SANDBOX=false

# ---- Supabase (auth + Postgres — Phase 4/5) ----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Congress trades (STOCK Act disclosures) ----
CONGRESS_TRADES_API_KEY=
CONGRESS_TRADES_API_BASE=

# ---- Optional ----
SEC_API_KEY=
PREDICTION_MARKET_API_KEY=
